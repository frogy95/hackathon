# 관리자 비밀번호 bcrypt 해시
# node -e "require('bcryptjs').hash('your-password', 10).then(console.log)" 으로 생성
# 주의: $가 포함된 bcrypt 해시는 \$로 이스케이프해야 합니다 (예: \$2b\$10\$...)
ADMIN_PASSWORD_HASH=

# JWT 서명 키 (32자 이상 랜덤 문자열)
# node -e "require('crypto').randomBytes(32).toString('hex')" 으로 생성
JWT_SECRET=

GITHUB_TOKEN=your-github-token
ANTHROPIC_API_KEY=your-anthropic-api-key

# DB 연결 설정
# 로컬 개발: file:./hackathon.db (기본값)
# Turso 호스팅: libsql://your-db-name.turso.io
DATABASE_URL=file:./hackathon.db

# Turso 인증 토큰 (로컬 파일 DB 사용 시 불필요, Turso 호스팅 시 필수)
# turso db tokens create your-db-name 으로 생성
DATABASE_AUTH_TOKEN=

# Gmail SMTP 이메일 발송 설정
# Gmail 2단계 인증 활성화 후 앱 비밀번호 발급 필요
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
# 발신자 이름 및 이메일
EMAIL_FROM=해커톤 평가 시스템 <your-gmail@gmail.com>

# 앱 공개 URL (이메일 링크 생성에 사용)
NEXT_PUBLIC_APP_URL=https://hackathon.ubcare.co.kr

# Vercel 배포 시 Playwright 스크린샷 비활성화 (용량 초과 방지)
# 로컬 개발: false (스크린샷 활성화)
# Vercel 배포: 반드시 true로 설정 (Serverless 환경에서 Chromium 실행 불가)
DISABLE_SCREENSHOTS=false
